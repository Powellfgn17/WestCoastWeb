# Resend — Email delivery for contact form
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=

# "From" address — must be a verified domain on Resend
# Default: "Powell Digital <onboarding@resend.dev>" (Resend sandbox)
RESEND_FROM_EMAIL=

# Where contact form submissions are delivered
CONTACT_EMAIL=hello@powelldigital.com
